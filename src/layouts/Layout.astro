---
import '../styles/global.css';
import LogoTitle from '../components/LogoTitle.astro';
const path = Astro.url.pathname.replace(/\/$/, '');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Metamorphous&family=Cinzel:wght@400;600&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Metamorphous&family=Cinzel:wght@400;600&display=swap" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Metamorphous&family=Cinzel:wght@400;600&display=swap" /></noscript>
		<title>Fragua47</title>
	</head>
	<body>

		<div class="header-wrap">
			<header>
				<div class="header-top">
					<LogoTitle />
					<button class="hamburger" aria-label="Menú" aria-expanded="false">
						<span></span><span></span><span></span>
					</button>
				</div>
				<nav id="main-nav">
					<a href="/eventos"        class={path === '/eventos'        ? 'active' : ''}>Eventos</a>
					<a href="/normas"          class={path === '/normas'          ? 'active' : ''}>Normas</a>
					<a href="/sobre-nosotros"  class={path === '/sobre-nosotros'  ? 'active' : ''}>Sobre nosotros</a>
					<a href="/local"           class={path === '/local'           ? 'active' : ''}>Local</a>
					<a href="/hazte-socio"     class={path === '/hazte-socio'     ? 'active' : ''}>Hazte socio</a>
					<a href="/contacto"        class={path === '/contacto'        ? 'active' : ''}>Contacto</a>
				</nav>
			</header>
		</div>

		<main>
			<slot />
		</main>

		<svg width="0" height="0" style="position:absolute">
			<defs>
				<filter id="parchment-edge" x="-5%" y="-5%" width="110%" height="110%">
					<feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="4" seed="8" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="ink-stroke" x="-5%" y="-50%" width="110%" height="200%">
					<feTurbulence type="fractalNoise" baseFrequency="0.85 0.25" numOctaves="2" seed="5" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="quill-ink" x="-5%" y="-5%" width="110%" height="110%">
					<!-- Engrosar trazos: simula pluma cargada de tinta -->
					<feMorphology operator="dilate" radius="0.25 0.15" in="SourceGraphic" result="thick"/>
					<!-- Irregularidad suave en los bordes -->
					<feTurbulence type="fractalNoise" baseFrequency="0.8 0.35" numOctaves="3" seed="12" result="disp-noise"/>
					<feDisplacementMap in="thick" in2="disp-noise" scale="0.8" xChannelSelector="R" yChannelSelector="G" result="displaced"/>
					<!-- Recortar para no salir demasiado del contorno -->
					<feComposite in="displaced" in2="thick" operator="atop"/>
				</filter>
			</defs>
		</svg>

	</body>
</html>

<script is:inline>
	function matchMainToHeader() {
		const header = document.querySelector('header');
		const main   = document.querySelector('main');
		if (!header || !main) return;
		if (window.innerWidth <= 768) {
			main.style.width = '100%';
			main.style.padding = '1rem';
		} else {
			main.style.width = header.offsetWidth + 'px';
			main.style.padding = '';
		}
	}
	window.addEventListener('DOMContentLoaded', matchMainToHeader);
	window.addEventListener('resize', matchMainToHeader);

	window.addEventListener('DOMContentLoaded', () => {
		const btn = document.querySelector('.hamburger');
		const nav = document.getElementById('main-nav');
		btn?.addEventListener('click', () => {
			const open = nav.classList.toggle('open');
			btn.setAttribute('aria-expanded', open);
		});
	});
</script>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	html { background: #e8dcc8; color: #1c0f06; }
	body {
		font-family: 'Cinzel', serif;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	body::before {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background:
			/* esquina top-left */
			radial-gradient(ellipse 320px 280px at -2% -2%,   rgba(60, 22, 3, 0.20) 0%, transparent 70%),
			/* esquina top-right */
			radial-gradient(ellipse 280px 260px at 102% -2%,  rgba(50, 18, 2, 0.18) 0%, transparent 70%),
			/* esquina bottom-left */
			radial-gradient(ellipse 300px 300px at -2% 102%,  rgba(55, 20, 3, 0.19) 0%, transparent 70%),
			/* esquina bottom-right */
			radial-gradient(ellipse 340px 280px at 102% 102%, rgba(45, 16, 2, 0.20) 0%, transparent 70%),
			/* margen izquierdo */
			radial-gradient(ellipse 180px 200px at -1% 38%,   rgba(40, 14, 2, 0.13) 0%, transparent 70%),
			radial-gradient(ellipse 140px 160px at -1% 65%,   rgba(35, 12, 1, 0.11) 0%, transparent 65%),
			/* margen derecho */
			radial-gradient(ellipse 200px 180px at 101% 45%,  rgba(50, 18, 2, 0.14) 0%, transparent 70%),
			radial-gradient(ellipse 150px 200px at 101% 72%,  rgba(40, 14, 2, 0.12) 0%, transparent 65%),
			/* margen superior */
			radial-gradient(ellipse 220px 120px at 35%  -1%,  rgba(45, 16, 2, 0.12) 0%, transparent 70%),
			/* margen inferior */
			radial-gradient(ellipse 260px 140px at 65%  101%, rgba(50, 18, 2, 0.13) 0%, transparent 70%);
	}

	body::after {
		content: '';
		position: fixed;
		inset: -6px;
		pointer-events: none;
		z-index: 9999;
		border: 12px solid rgba(80, 30, 5, 0.2);
		filter: blur(3px) url(#parchment-edge);
	}

	.header-wrap {
		position: sticky;
		top: 0;
		z-index: 50;
		width: 100%;
		background: #b89a6a;
		border-bottom: 2px solid #6a3e14;
		display: flex;
		justify-content: center;
	}

	header {
		display: flex;
		align-items: flex-start;
		gap: 1.4rem;
		padding-top: 1rem;
		height: 120px;
		width: fit-content;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1.3rem;
		padding-top: 3.4rem;
	}

	@keyframes draw-line {
		from { transform: scaleX(0); }
		to   { transform: scaleX(1); }
	}
	@keyframes feather-write {
		0%   { left: 0%;   opacity: 1; }
		100% { left: 100%; opacity: 1; }
	}

	nav a {
		font-family: 'Cinzel', serif;
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		text-decoration: none;
		color: #3a1a04;
		padding-bottom: 0.2rem;
		position: relative;
		transition: color 0.3s ease, text-shadow 0.3s ease;
	}
	nav a::before {
		content: '';
		position: absolute;
		bottom: 0.1rem;
		width: 0.9rem;
		height: 1.1rem;
		background: url('/pluma.svg') no-repeat center / contain;
		opacity: 0;
		pointer-events: none;
	}
	nav a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 2px;
		width: 100%;
		background: #1a0a02;
		filter: url(#ink-stroke);
		transform: scaleX(0);
		transform-origin: left center;
		pointer-events: none;
	}
	nav a:hover,
	nav a.active {
		color: #a84e18;
		text-shadow: 0 0 10px rgba(160, 70, 15, 0.4);
	}

	nav a.active::after {
		transform: scaleX(1);
	}
	nav a:hover::after {
		animation: draw-line 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}
	nav a:hover::before {
		animation: feather-write 0.95s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}

	main {
		padding: 1.5rem 0;
	}

	/* ── Hamburger ── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4rem;
	}
	.hamburger span {
		display: block;
		width: 26px;
		height: 2px;
		background: #3a1a04;
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	/* ── Mobile ── */
	@media (max-width: 768px) {
		header {
			flex-direction: column;
			height: auto;
			width: 100%;
			padding: 0.8rem 1rem;
			gap: 0;
		}

		.header-top {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
		}

		.hamburger { display: flex; }

		nav {
			display: none;
			flex-direction: column;
			align-items: flex-start;
			padding-top: 0.8rem;
			padding-bottom: 0.5rem;
			gap: 0.9rem;
			width: 100%;
		}
		nav.open { display: flex; }

		nav a {
			font-size: 0.95rem;
			letter-spacing: 1px;
		}
	}

	@media (min-width: 769px) {
		.header-top { display: contents; }
	}
</style>
