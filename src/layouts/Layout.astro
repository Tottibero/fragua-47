---
import '../styles/global.css';
import LogoTitle from '../components/LogoTitle.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link href="https://fonts.googleapis.com/css2?family=Metamorphous&family=Cinzel:wght@400;600&display=swap" rel="stylesheet" />
		<title>Fragua47</title>
	</head>
	<body>

		<div id="loader" style="position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center">
			<img src="/forjatransparente.gif" alt="Cargando..." id="loader-gif" />
		</div>

		<div class="header-wrap">
		<header>
				<LogoTitle />
				<nav>
					<a href="/eventos"        class={Astro.url.pathname === '/eventos'        ? 'active' : ''}>Eventos</a>
					<a href="/normas"          class={Astro.url.pathname === '/normas'          ? 'active' : ''}>Normas</a>
					<a href="/sobre-nosotros"  class={Astro.url.pathname === '/sobre-nosotros'  ? 'active' : ''}>Sobre nosotros</a>
					<a href="/local"           class={Astro.url.pathname === '/local'           ? 'active' : ''}>Local</a>
					<a href="/contacto"        class={Astro.url.pathname === '/contacto'        ? 'active' : ''}>Contacto</a>
				</nav>
		</header>
		</div>

		<main>
			<slot />
		</main>

		<svg width="0" height="0" style="position:absolute">
			<defs>
				<filter id="parchment-edge" x="-5%" y="-5%" width="110%" height="110%">
					<feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="4" seed="8" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="ink-stroke" x="-5%" y="-50%" width="110%" height="200%">
					<feTurbulence type="fractalNoise" baseFrequency="0.85 0.25" numOctaves="2" seed="5" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="quill-ink" x="-5%" y="-5%" width="110%" height="110%">
					<!-- Engrosar trazos: simula pluma cargada de tinta -->
					<feMorphology operator="dilate" radius="0.25 0.15" in="SourceGraphic" result="thick"/>
					<!-- Irregularidad suave en los bordes -->
					<feTurbulence type="fractalNoise" baseFrequency="0.8 0.35" numOctaves="3" seed="12" result="disp-noise"/>
					<feDisplacementMap in="thick" in2="disp-noise" scale="0.8" xChannelSelector="R" yChannelSelector="G" result="displaced"/>
					<!-- Recortar para no salir demasiado del contorno -->
					<feComposite in="displaced" in2="thick" operator="atop"/>
				</filter>
			</defs>
		</svg>

	</body>
</html>

<script is:inline>
	const GIF_DURATION = 1000;

	function matchMainToHeader() {
		const header = document.querySelector('header');
		const main   = document.querySelector('main');
		if (header && main) main.style.width = header.offsetWidth + 'px';
	}
	window.addEventListener('DOMContentLoaded', matchMainToHeader);
	window.addEventListener('resize', matchMainToHeader);

	window.addEventListener('DOMContentLoaded', () => {
		const loader = document.getElementById('loader');
		const headerWrap = document.querySelector('.header-wrap');
		const main = document.querySelector('main');

		if (sessionStorage.getItem('intro-done')) {
			loader.remove();
			headerWrap.style.clipPath = 'none';
			main.classList.add('visible');
			return;
		}

		setTimeout(() => {
			loader.classList.add('fade-out');
			headerWrap.classList.add('unroll');
			headerWrap.addEventListener('animationend', () => {
				main.classList.add('visible');
				sessionStorage.setItem('intro-done', '1');
			}, { once: true });
			loader.addEventListener('transitionend', () => loader.remove(), { once: true });
		}, GIF_DURATION);
	});
</script>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	html { background: #e8dcc8; color: #1c0f06; }
	body {
		font-family: 'Cinzel', serif;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	body::after {
		content: '';
		position: fixed;
		inset: -6px;
		pointer-events: none;
		z-index: 9999;
		border: 12px solid rgba(80, 30, 5, 0.2);
		filter: blur(3px) url(#parchment-edge);
	}

	/* ── Parchment unroll ── */
	@keyframes unroll {
		0%   { clip-path: inset(0 0 100% 0); }
		100% { clip-path: inset(0 0 0% 0); }
	}

	.header-wrap {
		clip-path: inset(0 0 100% 0);
		position: sticky;
		top: 0;
		z-index: 50;
		width: 100%;
		background: #b89a6a;
		border-bottom: 2px solid #6a3e14;
		display: flex;
		justify-content: center;
	}

	header {
		display: flex;
		align-items: flex-start;
		gap: 1.4rem;
		padding-top: 1rem;
		height: 120px;
		width: fit-content;
	}

	.header-wrap.unroll {
		animation: unroll 2.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
	}


	nav {
		display: flex;
		align-items: center;
		gap: 1.3rem;
		padding-top: 3.4rem;
	}

	@keyframes draw-line {
		from { transform: scaleX(0); }
		to   { transform: scaleX(1); }
	}
	@keyframes feather-write {
		0%   { left: 0%;   opacity: 1; }
		100% { left: 100%; opacity: 1; }
	}

	nav a {
		font-family: 'Cinzel', serif;
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		text-decoration: none;
		color: #3a1a04;
		padding-bottom: 0.2rem;
		position: relative;
		transition: color 0.3s ease, text-shadow 0.3s ease;
	}
	nav a::before {
		content: '';
		position: absolute;
		bottom: 0.1rem;
		width: 0.9rem;
		height: 1.1rem;
		background: url('/pluma.svg') no-repeat center / contain;
		opacity: 0;
		pointer-events: none;
	}
	nav a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 2px;
		width: 100%;
		background: #1a0a02;
		filter: url(#ink-stroke);
		transform: scaleX(0);
		transform-origin: left center;
		pointer-events: none;
	}
	nav a:hover,
	nav a.active {
		color: #a84e18;
		text-shadow: 0 0 10px rgba(160, 70, 15, 0.4);
	}

	nav a.active::after {
		transform: scaleX(1);
	}
	nav a:hover::after {
		animation: draw-line 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}
	nav a:hover::before {
		animation: feather-write 0.95s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}

	main {
		padding: 1.5rem 0;
		opacity: 0;
		transition: opacity 0.8s ease;
	}
	main.visible { opacity: 1; }

	/* ── Loader ── */
	#loader { transition: opacity 0.6s ease; }
	#loader.fade-out { opacity: 0; pointer-events: none; }
	#loader-gif { max-height: 60vh; max-width: 60vw; }
</style>
