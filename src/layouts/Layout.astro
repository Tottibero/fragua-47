---
import '../styles/global.css';
import LogoTitle from '../components/LogoTitle.astro';
import cinzel400 from '@fontsource/cinzel/files/cinzel-latin-400-normal.woff2?url';
import cinzel600 from '@fontsource/cinzel/files/cinzel-latin-600-normal.woff2?url';
import metamorphous from '@fontsource/metamorphous/files/metamorphous-latin-400-normal.woff2?url';
const path = Astro.url.pathname.replace(/\/$/, '');
const { description = 'Fragua47 — Comunidad BDSM' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preload" as="font" type="font/woff2" href={cinzel400} crossorigin />
		<link rel="preload" as="font" type="font/woff2" href={cinzel600} crossorigin />
		<link rel="preload" as="font" type="font/woff2" href={metamorphous} crossorigin />
		<meta name="description" content={description} />
		<title>Fragua47</title>
		<slot name="head" />
	</head>
	<body>

		<div class="header-wrap">
			<header>
				<div class="header-top">
					<LogoTitle />
					<button class="hamburger" aria-label="Menú" aria-expanded="false">
						<span></span><span></span><span></span>
					</button>
				</div>
				<nav id="main-nav">
					<a href="/eventos/"        class={path === '/eventos'        ? 'active' : ''}>Eventos</a>
					<a href="/hazte-socio/"    class={path === '/hazte-socio'     ? 'active' : ''}>Hazte socio</a>
					<a href="/contacto/"       class={path === '/contacto'        ? 'active' : ''}>Contacto</a>
				</nav>
			</header>
		</div>

		<main>
			<slot />
		</main>

		<svg width="0" height="0" style="position:absolute">
			<defs>
				<filter id="parchment-edge" x="-5%" y="-5%" width="110%" height="110%">
					<feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="4" seed="8" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="ink-stroke" x="-5%" y="-50%" width="110%" height="200%">
					<feTurbulence type="fractalNoise" baseFrequency="0.85 0.25" numOctaves="2" seed="5" result="noise"/>
					<feDisplacementMap in="SourceGraphic" in2="noise" scale="2.5" xChannelSelector="R" yChannelSelector="G"/>
				</filter>
				<filter id="quill-ink" x="-5%" y="-5%" width="110%" height="110%">
					<!-- Engrosar trazos: simula pluma cargada de tinta -->
					<feMorphology operator="dilate" radius="0.25 0.15" in="SourceGraphic" result="thick"/>
					<!-- Irregularidad suave en los bordes -->
					<feTurbulence type="fractalNoise" baseFrequency="0.8 0.35" numOctaves="3" seed="12" result="disp-noise"/>
					<feDisplacementMap in="thick" in2="disp-noise" scale="0.8" xChannelSelector="R" yChannelSelector="G" result="displaced"/>
					<!-- Recortar para no salir demasiado del contorno -->
					<feComposite in="displaced" in2="thick" operator="atop"/>
				</filter>
			</defs>
		</svg>

	</body>
</html>

<style is:global>
	.nav-spark {
		position: fixed;
		width: var(--size);
		height: var(--size);
		border-radius: 50%;
		background: var(--color);
		pointer-events: none;
		z-index: 10000;
		animation: spark-burst var(--duration) ease-out forwards;
	}
	@keyframes spark-burst {
		0%   { transform: translate(0, 0) scale(1.2); opacity: 1; }
		60%  { opacity: 0.8; }
		100% { transform: translate(var(--dx), var(--dy)) scale(0); opacity: 0; }
	}
	nav a.golpe {
		display: inline-block;
		transform-origin: left center;
		animation: barra-golpe 4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
	}
	nav a.golpe::after {
		transform-origin: right center;
		animation: ember-aparece 0.8s ease-in forwards !important;
	}
	@keyframes ember-aparece {
		0%   { transform: scaleX(0); opacity: 0; }
		40%  { opacity: 0.4; }
		100% { transform: scaleX(1); opacity: 1; }
	}
	@keyframes barra-golpe {
		0%   { transform: rotate(0deg)    translateX(0px);  }
		6%   { transform: rotate(8deg)    translateX(5px);  }
		18%  { transform: rotate(-5deg)   translateX(-3px); }
		30%  { transform: rotate(3deg)    translateX(2px);  }
		42%  { transform: rotate(-2deg)   translateX(-1px); }
		55%  { transform: rotate(1deg)    translateX(1px);  }
		67%  { transform: rotate(-0.6deg) translateX(0px);  }
		80%  { transform: rotate(0.3deg)  translateX(0px);  }
		100% { transform: rotate(0deg)    translateX(0px);  }
	}
</style>

<script is:inline>
	function matchMainToHeader() {
		const header = document.querySelector('header');
		const main   = document.querySelector('main');
		if (!header || !main) return;
		if (window.innerWidth <= 768) {
			main.style.width = '100%';
			main.style.padding = '1rem';
		} else {
			main.style.width = header.offsetWidth + 'px';
			main.style.padding = '';
		}
	}
	window.addEventListener('DOMContentLoaded', matchMainToHeader);
	window.addEventListener('resize', matchMainToHeader);

	window.addEventListener('DOMContentLoaded', () => {
		const btn = document.querySelector('.hamburger');
		const nav = document.getElementById('main-nav');
		btn?.addEventListener('click', () => {
			const open = nav.classList.toggle('open');
			btn.setAttribute('aria-expanded', open);
		});
	});

	const colors = ['#ffcc00', '#ffaa00', '#ff8800', '#ff5500', '#ffee88'];

	function createSparks(el) {
		const rect = el.getBoundingClientRect();
		for (let i = 0; i < 18; i++) {
			const spark = document.createElement('span');
			spark.className = 'nav-spark';
			const angle = (Math.random() * 260) - 130;
			const dist = 30 + Math.random() * 60;
			const dx = Math.sin(angle * Math.PI / 180) * dist;
			const dy = -(Math.abs(Math.cos(angle * Math.PI / 180)) * dist + 15);
			spark.style.cssText = `
				left:${(rect.left + Math.random() * rect.width).toFixed(1)}px;
				top:${(rect.bottom - 2).toFixed(1)}px;
				--dx:${dx.toFixed(1)}px;
				--dy:${dy.toFixed(1)}px;
				--size:${(2 + Math.random() * 5).toFixed(1)}px;
				--color:${colors[Math.floor(Math.random() * colors.length)]};
				--duration:${(0.7 + Math.random() * 0.6).toFixed(2)}s;
				animation-delay:${(Math.random() * 0.15).toFixed(2)}s;
			`;
			document.body.appendChild(spark);
			spark.addEventListener('animationend', () => spark.remove());
		}
	}

	function spawnSpark(sx, sy, angle, dist) {
		const spark = document.createElement('span');
		spark.className = 'nav-spark';
		const dx = Math.sin(angle * Math.PI / 180) * dist;
		const dy = -(Math.abs(Math.cos(angle * Math.PI / 180)) * dist + 10);
		spark.style.cssText = `
			left:${sx.toFixed(1)}px;
			top:${sy.toFixed(1)}px;
			--dx:${dx.toFixed(1)}px;
			--dy:${dy.toFixed(1)}px;
			--size:${(1.5 + Math.random() * 3).toFixed(1)}px;
			--color:${colors[Math.floor(Math.random() * colors.length)]};
			--duration:${(0.5 + Math.random() * 0.5).toFixed(2)}s;
			animation-delay:${(Math.random() * 0.1).toFixed(2)}s;
		`;
		document.body.appendChild(spark);
		spark.addEventListener('animationend', () => spark.remove());
	}

	function createFewSparksAllSides(el) {
		const rect = el.getBoundingClientRect();
		const count = 3 + Math.floor(Math.random() * 4);
		for (let i = 0; i < count; i++) {
			const edge = Math.floor(Math.random() * 4);
			let sx, sy, angle;
			if (edge === 0) {
				sx = rect.left + Math.random() * rect.width;
				sy = rect.top + 2;
				angle = -(50 + Math.random() * 80);
			} else if (edge === 1) {
				sx = rect.right - 2;
				sy = rect.top + Math.random() * rect.height;
				angle = 20 + Math.random() * 140;
			} else if (edge === 2) {
				sx = rect.left + Math.random() * rect.width;
				sy = rect.bottom - 2;
				angle = -(Math.random() * 260 - 130);
			} else {
				sx = rect.left + 2;
				sy = rect.top + Math.random() * rect.height;
				angle = -(160 + Math.random() * 140);
			}
			spawnSpark(sx, sy, angle, 15 + Math.random() * 35);
		}
	}

	function createSparksAllSides(el) {
		const rect = el.getBoundingClientRect();
		for (let i = 0; i < 60; i++) {
			const spark = document.createElement('span');
			spark.className = 'nav-spark';
			const edge = Math.floor(Math.random() * 4);
			let sx, sy, angle;
			if (edge === 0) {
				sx = rect.left + Math.random() * rect.width;
				sy = rect.top + 2;
				angle = -(50 + Math.random() * 80);
			} else if (edge === 1) {
				sx = rect.right - 2;
				sy = rect.top + Math.random() * rect.height;
				angle = 20 + Math.random() * 140;
			} else if (edge === 2) {
				sx = rect.left + Math.random() * rect.width;
				sy = rect.bottom - 2;
				angle = -(Math.random() * 260 - 130);
			} else {
				sx = rect.left + 2;
				sy = rect.top + Math.random() * rect.height;
				angle = -(160 + Math.random() * 140);
			}
			const dist = 30 + Math.random() * 60;
			const dx = Math.sin(angle * Math.PI / 180) * dist;
			const dy = -(Math.abs(Math.cos(angle * Math.PI / 180)) * dist + 15);
			spark.style.cssText = `
				left:${sx.toFixed(1)}px;
				top:${sy.toFixed(1)}px;
				--dx:${dx.toFixed(1)}px;
				--dy:${dy.toFixed(1)}px;
				--size:${(2 + Math.random() * 5).toFixed(1)}px;
				--color:${colors[Math.floor(Math.random() * colors.length)]};
				--duration:${(0.7 + Math.random() * 0.6).toFixed(2)}s;
				animation-delay:${(Math.random() * 0.15).toFixed(2)}s;
			`;
			document.body.appendChild(spark);
			spark.addEventListener('animationend', () => spark.remove());
		}
	}

	const logoText = document.querySelector('.logo-metalico');
	let logoSparkInterval = null;
	document.querySelector('.logo-brand')?.addEventListener('mouseenter', () => {
		if (logoText) {
			createSparksAllSides(logoText);
			logoSparkInterval = setInterval(() => createFewSparksAllSides(logoText), 500);
		}
	});
	document.querySelector('.logo-brand')?.addEventListener('mouseleave', () => {
		clearInterval(logoSparkInterval);
		logoSparkInterval = null;
	});

	document.querySelectorAll('nav a').forEach(link => {
		let navSparkInterval = null;
		link.addEventListener('mouseenter', () => {
			createSparksAllSides(link);
			navSparkInterval = setInterval(() => createFewSparksAllSides(link), 500);
		});
		link.addEventListener('mouseleave', () => {
			clearInterval(navSparkInterval);
			navSparkInterval = null;
		});
		link.addEventListener('click', (e) => {
			const href = link.getAttribute('href');
			if (!href || href.startsWith('#')) return;
			e.preventDefault();
			link.classList.add('golpe');
			createSparks(link);
			setTimeout(() => {
				window.location.href = href;
			}, 400);
		});
	});

	function createFewSparks(el) {
		const rect = el.getBoundingClientRect();
		const count = 2 + Math.floor(Math.random() * 4);
		for (let i = 0; i < count; i++) {
			const spark = document.createElement('span');
			spark.className = 'nav-spark';
			const angle = (Math.random() * 200) - 100;
			const dist = 15 + Math.random() * 35;
			const dx = Math.sin(angle * Math.PI / 180) * dist;
			const dy = -(Math.abs(Math.cos(angle * Math.PI / 180)) * dist + 8);
			spark.style.cssText = `
				left:${(rect.left + Math.random() * rect.width).toFixed(1)}px;
				top:${(rect.bottom - 2).toFixed(1)}px;
				--dx:${dx.toFixed(1)}px;
				--dy:${dy.toFixed(1)}px;
				--size:${(1.5 + Math.random() * 3).toFixed(1)}px;
				--color:${colors[Math.floor(Math.random() * colors.length)]};
				--duration:${(0.5 + Math.random() * 0.5).toFixed(2)}s;
				animation-delay:${(Math.random() * 0.1).toFixed(2)}s;
			`;
			document.body.appendChild(spark);
			spark.addEventListener('animationend', () => spark.remove());
		}
	}

	setInterval(() => {
		const active = document.querySelector('nav a.active');
		if (active && Math.random() < 0.4) createFewSparks(active);
	}, 800);
</script>

<style>
	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	html { background: #e8dcc8; color: #1c0f06; }
	body {
		font-family: 'Cinzel', serif;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	body::before {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background:
			/* esquina top-left */
			radial-gradient(ellipse 320px 280px at -2% -2%,   rgba(60, 22, 3, 0.20) 0%, transparent 70%),
			/* esquina top-right */
			radial-gradient(ellipse 280px 260px at 102% -2%,  rgba(50, 18, 2, 0.18) 0%, transparent 70%),
			/* esquina bottom-left */
			radial-gradient(ellipse 300px 300px at -2% 102%,  rgba(55, 20, 3, 0.19) 0%, transparent 70%),
			/* esquina bottom-right */
			radial-gradient(ellipse 340px 280px at 102% 102%, rgba(45, 16, 2, 0.20) 0%, transparent 70%),
			/* margen izquierdo */
			radial-gradient(ellipse 180px 200px at -1% 38%,   rgba(40, 14, 2, 0.13) 0%, transparent 70%),
			radial-gradient(ellipse 140px 160px at -1% 65%,   rgba(35, 12, 1, 0.11) 0%, transparent 65%),
			/* margen derecho */
			radial-gradient(ellipse 200px 180px at 101% 45%,  rgba(50, 18, 2, 0.14) 0%, transparent 70%),
			radial-gradient(ellipse 150px 200px at 101% 72%,  rgba(40, 14, 2, 0.12) 0%, transparent 65%),
			/* margen superior */
			radial-gradient(ellipse 220px 120px at 35%  -1%,  rgba(45, 16, 2, 0.12) 0%, transparent 70%),
			/* margen inferior */
			radial-gradient(ellipse 260px 140px at 65%  101%, rgba(50, 18, 2, 0.13) 0%, transparent 70%);
	}

	body::after {
		content: '';
		position: fixed;
		inset: -6px;
		pointer-events: none;
		z-index: 9999;
		border: 12px solid rgba(80, 30, 5, 0.2);
		filter: blur(3px) url(#parchment-edge);
	}

	.header-wrap {
		position: sticky;
		top: 0;
		z-index: 50;
		width: 100%;
		background: #b89a6a;
		border-bottom: 2px solid #6a3e14;
		display: flex;
		justify-content: center;
	}

	header {
		display: flex;
		align-items: flex-start;
		gap: 1.4rem;
		padding-top: 1rem;
		height: 120px;
		width: fit-content;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1.3rem;
		padding-top: 3.4rem;
	}

	@keyframes ember-trail {
		0%   { transform: scaleX(0); opacity: 1; }
		100% { transform: scaleX(1); opacity: 1; }
	}
	@keyframes spark-fly {
		0%   { left: -4px;   opacity: 0; transform: translateY(0) scale(1); }
		10%  { opacity: 1; }
		80%  { opacity: 1; transform: translateY(-2px) scale(1.2); }
		100% { left: calc(100% + 2px); opacity: 0; transform: translateY(1px) scale(0.6); }
	}
	@keyframes ember-glow {
		0%, 100% { opacity: 0.7; box-shadow: 0 0 4px 1px #ff6a00, 0 0 8px 2px #c84400; }
		50%       { opacity: 1;   box-shadow: 0 0 6px 2px #ffaa00, 0 0 12px 4px #ff6a00; }
	}

	nav a {
		font-family: 'Cinzel', serif;
		font-size: 1.1rem;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		text-decoration: none;
		color: #3a1a04;
		padding-bottom: 0.2rem;
		position: relative;
		transition: color 0.3s ease, text-shadow 0.3s ease;
	}
	/* chispa que vuela */
	nav a::before {
		content: '';
		position: absolute;
		bottom: 2px;
		width: 5px;
		height: 5px;
		border-radius: 50% 50% 50% 0;
		background: #ffaa00;
		opacity: 0;
		pointer-events: none;
		transform-origin: center;
	}
	/* brasa bajo el texto */
	nav a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: 0;
		height: 2px;
		width: 100%;
		background: linear-gradient(to right, #c84400, #ff8c00, #ffcc00, #ff8c00, #c84400);
		transform: scaleX(0);
		transform-origin: left center;
		pointer-events: none;
	}
	nav a:hover,
	nav a.active {
		color: #c85a10;
		text-shadow: 0 0 8px rgba(220, 100, 10, 0.5), 0 0 20px rgba(180, 60, 0, 0.25);
	}
	nav a.active::after {
		transform: scaleX(1);
		animation: ember-glow 2s ease-in-out infinite;
	}

	main {
		padding: 1.5rem 0;
	}


	/* ── Hamburger ── */
	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.4rem;
	}
	.hamburger span {
		display: block;
		width: 26px;
		height: 2px;
		background: #3a1a04;
		transition: transform 0.3s ease, opacity 0.3s ease;
	}

	/* ── Mobile ── */
	@media (max-width: 768px) {
		header {
			flex-direction: column;
			height: auto;
			width: 100%;
			padding: 0.8rem 1rem;
			gap: 0;
		}

		.header-top {
			display: flex;
			align-items: center;
			justify-content: space-between;
			width: 100%;
		}

		.hamburger { display: flex; }

		nav {
			display: none;
			flex-direction: column;
			align-items: flex-start;
			padding-top: 0.8rem;
			padding-bottom: 0.5rem;
			gap: 0.9rem;
			width: 100%;
		}
		nav.open { display: flex; }

		nav a {
			font-size: 0.95rem;
			letter-spacing: 1px;
		}
	}

	@media (min-width: 769px) {
		.header-top { display: contents; }
	}
</style>
