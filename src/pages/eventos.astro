---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eventos" description="Próximos eventos de Fragua47. Consulta la agenda de quedadas y actividades de la comunidad.">
	<div class="pagina">

		<!-- Columna izquierda: próximos eventos -->
		<div class="proximos-wrap">
			<div class="proximos-header">
				<img src="/VectLogoF47.webp" alt="Logo Fragua47" class="proximos-logo" width="300" height="343" />
				<h2 class="proximos-titulo">Próximos Eventos</h2>
				<div class="proximos-sep"></div>
			</div>
			<ul class="proximos-lista" id="proximos-lista"></ul>
		</div>

		<!-- Evento: poster style -->
		<div class="evento-stack">
			<img src="/fetish-uniform.png" alt="Fetish Uniform Night" class="img-evento-bg" loading="lazy" width="797" height="453" />
			<div class="evento-overlay"></div>
			<div class="evento-content">
				<div class="evento-top">
					<img src="/VectLogoF47.webp" alt="Logo Fragua47" class="evento-logo" width="300" height="343" />
					<span class="logo-metalico">FRAGUA47</span>
				</div>
				<div class="evento-bottom">
					<div class="evento-info">
						<h3>Fetish Uniform <span class="accent">Night</span></h3>
						<div class="evento-fecha">
							<span class="fecha-dia">2</span>
							<span class="fecha-div"></span>
							<div class="fecha-detalle">
								<span class="fecha-mes">Mayo</span>
								<span class="fecha-sub">Sábado · 21:00 h · Valladolid</span>
							</div>
						</div>
						<div class="datos-evento">
							<div class="dato-fila">
								<svg class="dato-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
								<span class="dato-valor">Uniforme, fetish ó mínimo negro</span>
							</div>
							<div class="dato-fila">
								<svg class="dato-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
								<span class="dato-valor">Se indicará al confirmar asistencia</span>
							</div>
							<div class="dato-fila">
								<svg class="dato-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 22h8"/><path d="M7 10h10"/><path d="M12 15v7"/><path d="M12 15a5 5 0 0 0 5-5V3H7v7a5 5 0 0 0 5 5z"/></svg>
								<span class="dato-valor">Picoteo incluido</span>
							</div>
						</div>
					</div>
					<div class="footer-card">
						<button class="btn-inscribete" id="btn-inscribete">Inscríbete ⚒</button>
					</div>
				</div>
			</div>
		</div>

			<!-- Calendario navegable -->
			<div class="calendario">
				<div class="cal-header">
					<button class="cal-nav" id="cal-prev">‹</button>
					<div class="cal-mes-wrap">
						<img src="/VectLogoF47.webp" alt="Logo Fragua47" class="cal-logo" width="300" height="343" />
						<p class="cal-pre">— agenda —</p>
						<h4 class="cal-titulo" id="cal-titulo"></h4>
					</div>
					<button class="cal-nav" id="cal-next">›</button>
				</div>
				<hr class="linea" />
				<div class="cal-grid" id="cal-grid"></div>
				<hr class="linea" />
				<ul class="agenda" id="agenda-list"></ul>
			</div>

	</div>

	<!-- Modal inscripción -->
	<div class="modal-overlay" id="modal-overlay">
		<div class="modal-documento">
			<button class="modal-cerrar" id="modal-cerrar" aria-label="Cerrar">✕</button>
			<div class="doc-header">
				<img src="/VectLogoF47.webp" alt="Logo Fragua47" class="modal-logo" width="300" height="343" />
				<h5>Inscripción</h5>
				<span class="doc-sello">⚒</span>
			</div>
			<p class="doc-sub">— Fetish Uniform Night · Fragua47 · Valladolid —</p>
			<hr class="doc-linea" />
			<form id="form-inscripcion">
				<div class="fila-campos">
					<div class="campo">
						<label for="correo-evento">Correo <span class="req">*</span></label>
						<input type="email" id="correo-evento" name="correo" required placeholder="tu@correo.com" />
					</div>
					<div class="campo">
						<label for="alias-evento">Alias <span class="req">*</span></label>
						<input type="text" id="alias-evento" name="alias" required placeholder="¿Cómo te conocemos?" />
					</div>
				</div>
				<div class="campo">
					<label for="fetlife-evento">FetLife <span class="opcional">(opcional)</span></label>
					<input type="text" id="fetlife-evento" name="fetlife" placeholder="Tu nick en FetLife" />
				</div>
				<hr class="doc-linea" />
				<div class="doc-footer">
					<p class="form-msg" id="inscripcion-msg"></p>
					<button type="submit" id="inscripcion-btn" class="btn-enviar">Enviar inscripción ⚒</button>
				</div>
			</form>
		</div>
	</div>

</Layout>

<script is:inline>
	// ── Modal ──
	const btn     = document.getElementById('btn-inscribete');
	const overlay = document.getElementById('modal-overlay');
	const cerrar  = document.getElementById('modal-cerrar');
	btn?.addEventListener('click', () => overlay.classList.add('abierto'));
	cerrar?.addEventListener('click', () => overlay.classList.remove('abierto'));
	overlay?.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('abierto'); });
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') overlay?.classList.remove('abierto');
	});

	document.getElementById('form-inscripcion')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = e.target;
		const ibtn = document.getElementById('inscripcion-btn');
		const msg  = document.getElementById('inscripcion-msg');
		ibtn.disabled = true; ibtn.textContent = 'Enviando...';
		msg.className = 'form-msg'; msg.textContent = '';
		const correo  = document.getElementById('correo-evento').value.trim();
		const alias   = document.getElementById('alias-evento').value.trim();
		const fetlife = document.getElementById('fetlife-evento').value.trim();
		const res = await fetch('/api/inscripcion', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ correo, alias, fetlife }) });
		if (res.ok) {
			msg.className = 'form-msg ok';
			msg.textContent = '¡Inscripción enviada! Te confirmamos pronto.';
			form.reset();
		} else {
			msg.className = 'form-msg error';
			msg.textContent = 'Error al enviar. Inténtalo de nuevo.';
		}
		ibtn.disabled = false; ibtn.textContent = 'Enviar inscripción ⚒';
	});

	// ── Próximos eventos (panel izquierdo) ──
	const MESES_FULL = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

	// ── Calendario ──
	const EVENTOS = [
		{ year: 2026, month: 2,  day: 14, nombre: 'D&B: Dungeons & Bondage' },
		{ year: 2026, month: 3,  day: 18, nombre: 'Fiesta Japan & Body Sushi' },
		{ year: 2026, month: 4,  day:  2, nombre: 'Fetish Uniform Night' },
		{ year: 2026, month: 5,  day:  6, nombre: 'Noche de Velas' },
		{ year: 2026, month: 6,  day:  4, nombre: 'Desfile Fetish Queer' },
		{ year: 2026, month: 7,  day:  1, nombre: 'Barbacoa & Escape Room' },
	];

	const MESES = MESES_FULL;
	const DIAS  = ['L','M','X','J','V','S','D'];

	const now = new Date();
	let curYear  = now.getFullYear();
	let curMonth = now.getMonth(); // 0-indexed

	function render() {
		const titulo = document.getElementById('cal-titulo');
		const grid   = document.getElementById('cal-grid');
		const agenda = document.getElementById('agenda-list');
		titulo.textContent = `${MESES[curMonth]} ${curYear}`;

		// Grid
		const firstDay = new Date(curYear, curMonth, 1).getDay(); // 0=Sun
		const offset   = firstDay === 0 ? 6 : firstDay - 1; // Mon-first
		const daysInMonth = new Date(curYear, curMonth + 1, 0).getDate();
		const today = new Date();

		let html = DIAS.map(d => `<span class="cal-dia-nombre">${d}</span>`).join('');
		for (let i = 0; i < offset; i++) html += `<span class="vacio"></span>`;
		for (let d = 1; d <= daysInMonth; d++) {
			const ev      = EVENTOS.find(e => e.year === curYear && e.month === curMonth && e.day === d);
			const isToday = curYear === today.getFullYear() && curMonth === today.getMonth() && d === today.getDate();
			const isPast  = new Date(curYear, curMonth, d) < new Date(today.getFullYear(), today.getMonth(), today.getDate());
			let cls = '';
			if (isToday && ev) cls = 'evento-dia hoy-dia';
			else if (isToday)  cls = 'hoy-dia';
			else if (ev && isPast) cls = 'evento-dia pasado-dia';
			else if (ev)       cls = 'evento-dia';
			html += `<span class="${cls}">${d}</span>`;
		}
		grid.innerHTML = html;

		// Agenda: solo eventos de este mes
		const mesEventos = EVENTOS.filter(e => e.year === curYear && e.month === curMonth);
		if (mesEventos.length === 0) {
			agenda.innerHTML = `<li class="sin-eventos"><span class="agenda-nombre">Sin eventos este mes</span></li>`;
		} else {
			agenda.innerHTML = mesEventos.map(e => {
				const isPast = new Date(curYear, curMonth, e.day) < new Date(today.getFullYear(), today.getMonth(), today.getDate());
				return `<li class="${isPast ? 'pasado' : ''}">
					<span class="agenda-fecha">${String(e.day).padStart(2,'0')} ${MESES[curMonth].slice(0,3)}</span>
					<span class="agenda-nombre">${e.nombre}</span>
				</li>`;
			}).join('');
		}
	}

	document.getElementById('cal-prev')?.addEventListener('click', () => {
		curMonth--; if (curMonth < 0) { curMonth = 11; curYear--; } render();
	});
	document.getElementById('cal-next')?.addEventListener('click', () => {
		curMonth++; if (curMonth > 11) { curMonth = 0; curYear++; } render();
	});

	render();

	// ── Render panel próximos eventos ──
	(function renderProximos() {
		const lista = document.getElementById('proximos-lista');
		if (!lista) return;
		const today = new Date();
		const todayMidnight = new Date(today.getFullYear(), today.getMonth(), today.getDate());
		const futuroIdx = EVENTOS.findIndex(e => new Date(e.year, e.month, e.day) >= todayMidnight);
		lista.innerHTML = EVENTOS.map((e, i) => {
			const isPast = new Date(e.year, e.month, e.day) < todayMidnight;
			const isNext = i === futuroIdx;
			return `<li class="prox-item${isPast ? ' prox-pasado' : ''}${isNext ? ' prox-next' : ''}">
				<div class="prox-sello">
					<span class="prox-dia">${e.day}</span>
					<span class="prox-mes">${MESES_FULL[e.month]}</span>
				</div>
				<div class="prox-pivot">⚒</div>
				<div class="prox-info">
					<span class="prox-nombre">${e.nombre}</span>
					${isPast ? '<span class="prox-check">✓</span>' : ''}
					${isNext ? '<span class="prox-badge">próxima</span>' : ''}
				</div>
			</li>`;
		}).join('');
	})();
</script>

<style>
	.pagina {
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		grid-template-rows: minmax(0, 1fr) auto;
		grid-template-areas:
			"foto stack"
			"foto cal";
		gap: 1rem;
		margin: 0.6rem auto 0.8rem;
		height: calc(100vh - 148px);
		align-items: stretch;
		overflow: hidden;
	}

	/* ── Panel Próximos Eventos (estructura, no dinámica) ── */

	.proximos-wrap {
		grid-area: foto;
		background: linear-gradient(to bottom, #1e1008 0%, #120802 100%);
		border: 3px solid #2a1208;
		outline: 1px solid rgba(210,120,40,0.5);
		outline-offset: 4px;
		box-shadow: 5px 5px 0 #2a1208;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		padding: 0.9rem 0.8rem 0.8rem;
		font-family: 'Cinzel', serif;
		position: relative;
	}

	.proximos-wrap::after {
		content: '';
		position: absolute;
		inset: 6px;
		border: 1px solid rgba(210,120,40,0.2);
		pointer-events: none;
	}

	.proximos-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
		margin-bottom: 0.6rem;
		flex-shrink: 0;
		position: relative;
		z-index: 1;
	}

	.proximos-logo { height: 30px; width: auto; opacity: 0.9; }

	.proximos-titulo {
		font-family: 'Metamorphous', cursive;
		font-size: 0.95rem;
		letter-spacing: 4px;
		text-transform: uppercase;
		background: linear-gradient(to bottom, #ffe0b0 0%, #f0a060 30%, #d07030 70%, #a04018 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		filter: brightness(1.4);
		margin: 0;
		text-align: center;
	}

	.proximos-sep {
		width: 55%;
		height: 1px;
		background: linear-gradient(to right, transparent, rgba(210,120,40,0.7), transparent);
	}

	.proximos-lista {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		flex: 1;
		justify-content: space-evenly;
		position: relative;
		z-index: 1;
	}

	/* ── Evento stack — poster style ── */

	.evento-stack {
		grid-area: stack;
		position: relative;
		overflow: hidden;
		border: 3px solid #2a1208;
		outline: 1px solid #2a1208;
		outline-offset: 4px;
		box-shadow: 5px 5px 0 #2a1208;
		background: #120802;
	}

	.img-evento-bg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: 66% 20%;
		display: block;
	}

	.evento-overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to bottom,
				rgba(18,8,2,0.35) 0%,
				rgba(18,8,2,0.1) 20%,
				rgba(18,8,2,0.5) 48%,
				rgba(18,8,2,0.88) 68%,
				#120802 85%
			);
	}

	.evento-content {
		position: relative;
		z-index: 10;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		padding: 0.6rem 0.8rem 0;
	}

	.evento-top {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		align-self: flex-end;
	}

	.evento-logo { height: 18px; width: auto; opacity: 0.95; flex-shrink: 0; }

	.logo-metalico {
		font-family: 'Metamorphous', cursive;
		font-size: 0.7rem;
		letter-spacing: 2px;
		background: linear-gradient(to bottom, #ffe0b0 0%, #f0a060 15%, #e08040 40%, #d07030 65%, #a04018 85%, #6a2808 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		filter: brightness(1.5);
	}

	.evento-bottom {
		position: absolute;
		bottom: 0.5rem;
		left: 0.8rem;
		right: 0.8rem;
		display: flex;
		flex-direction: row;
		align-items: flex-end;
		gap: 0.5rem;
	}

	.evento-info {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	h3 {
		font-family: 'Metamorphous', cursive;
		font-size: 1rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #f0d898;
		margin: 0;
		line-height: 1.1;
	}

	h3 .accent { color: #e0b080; }

	.evento-fecha {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.fecha-dia {
		font-family: 'Metamorphous', cursive;
		font-size: 1.6rem;
		color: #f0d898;
		line-height: 1;
	}

	.fecha-div {
		width: 1px;
		height: 1.4rem;
		background: rgba(240,216,152,0.3);
		flex-shrink: 0;
	}

	.fecha-detalle {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.fecha-mes {
		font-family: 'Cinzel', serif;
		font-size: 0.65rem;
		font-weight: 600;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: #f0d898;
	}

	.fecha-sub {
		font-family: 'Cinzel', serif;
		font-size: 0.55rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: rgba(240,216,152,0.85);
	}

	.datos-evento {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.dato-fila {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.18rem 0;
	}

	.dato-icon {
		width: 0.65rem;
		height: 0.65rem;
		min-width: 0.65rem;
		stroke: rgba(240,216,152,0.6);
		flex-shrink: 0;
	}

	.dato-valor {
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.6rem;
		color: rgba(240,216,152,0.85);
		line-height: 1.3;
	}

	.footer-card { display: flex; align-items: flex-end; flex-shrink: 0; }

	.linea {
		border: none;
		border-top: 1px solid rgba(240,216,152,0.15);
		margin: 0.2rem 0;
	}

	.btn-inscribete {
		background: #b44814;
		color: #fff7ee;
		border: none;
		padding: 0.45rem 1.1rem;
		font-family: 'Cinzel', serif;
		font-size: 0.6rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s, box-shadow 0.2s;
		box-shadow: 3px 3px 0 #6a2808;
	}

	.btn-inscribete:hover { background: #d45a18; box-shadow: 4px 4px 0 #6a2808; }

	/* ── Calendario ── */

	.calendario {
		grid-area: cal;
		background: #d4b896;
		border: 3px solid #2a1208;
		outline: 1px solid #2a1208;
		outline-offset: 4px;
		box-shadow: 5px 5px 0 #2a1208;
		padding: 0.5rem 0.8rem;
		font-family: 'Cinzel', serif;
		flex-shrink: 0;
	}

	.cal-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		margin-bottom: 0.1rem;
	}

	.cal-nav {
		background: #2a1208;
		border: none;
		color: #f5e6d0;
		font-size: 1.1rem;
		width: 28px;
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		flex-shrink: 0;
		padding: 0;
		line-height: 1;
		transition: background 0.15s;
	}

	.cal-nav:hover { background: #b44814; }

	.cal-logo {
		height: 18px;
		width: auto;
		opacity: 0.85;
		flex-shrink: 0;
	}

	.cal-mes-wrap {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.cal-pre {
		font-size: 0.42rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #5a3018;
		margin: 0;
	}

	h4.cal-titulo {
		font-family: 'Metamorphous', cursive;
		font-size: 0.85rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #2a1208;
		margin: 0;
		line-height: 1;
	}

	.cal-grid {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		gap: 0.1rem;
		margin: 0.25rem 0;
	}

	.cal-dia-nombre {
		font-family: 'Cinzel', serif;
		font-size: 0.45rem;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: #b44814;
		font-weight: 700;
		text-align: center;
		padding-bottom: 0.12rem;
		border-bottom: 1px solid rgba(42,18,8,0.2);
	}

	.cal-grid span:not(.cal-dia-nombre):not(.vacio) {
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.65rem;
		color: #2a1208;
		text-align: center;
		padding: 0.15rem 0;
		line-height: 1;
	}

	.vacio { visibility: hidden; }

	.agenda { list-style: none; padding: 0; margin: 0.1rem 0 0; }

	/* ── Agenda ── */

	.agenda {
		list-style: none;
		padding: 0;
		margin: 0.1rem 0 0;
		display: flex;
		flex-direction: column;
	}

	.agenda li {
		display: flex;
		align-items: baseline;
