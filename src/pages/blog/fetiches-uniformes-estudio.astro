        </div>
        <div class="tipo-item">
          <span class="tipo-icono" aria-hidden="true">✦</span>
          <span class="tipo-nombre">Sanitarios (enfermería, médico)</span>
        </div>
        <div class="tipo-item">
          <span class="tipo-icono" aria-hidden="true">✦</span>
          <span class="tipo-nombre">Uniformes escolares</span>
        </div>
        <div class="tipo-item">
          <span class="tipo-icono" aria-hidden="true">✦</span>
          <span class="tipo-nombre">Aviación (piloto, azafata)</span>
        </div>
