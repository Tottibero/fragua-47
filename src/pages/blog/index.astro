---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'fetiches-uniformes-estudio',
    titulo: 'El Uniforme Como Fantasía: Lo Que los Estudios Revelan Sobre un Deseo Muy Frecuente',
    resumen: 'El fetiche del uniforme es uno de los más documentados en la investigación sobre sexualidad. Qué dicen los estudios, la psicología del poder vestido y su lugar en la práctica BDSM.',
    fecha: '2026-04-28',
    fechaMostrar: '28 de abril de 2026',
    imagen: '/blog/uniformes/imagen-0.png',
    imagenAlt: 'Ilustración editorial sobre el fetiche del uniforme',
    etiquetas: ['Psicología', 'Estudios'],
    lectura: '15 min',
    autor: 'tottibero',
    autorURL: 'https://fetlife.com/tottibero',
  },
  {
    slug: 'shunga-abunae-eroguro-erotismo-arte-japones',
    titulo: 'Shunga, Abunae y Eroguro: La Evolución del Erotismo en el Arte Japonés',
    resumen: 'Del período Edo hasta la vanguardia del siglo XX, el arte erótico japonés recorrió un camino fascinante entre lo sagrado, lo prohibido y lo transgresor. Un viaje por el shunga, el abunae y el eroguro.',
    fecha: '2026-04-08',
    fechaMostrar: '8 de abril de 2026',
    imagen: '/blog/japan/Utamaro_(1793)_Three_Beauties_of_the_Present_Time.jpg',
    imagenAlt: 'Kitagawa Utamaro, Tres Bellezas del Tiempo Presente, 1793 — ukiyo-e, período Edo',
    etiquetas: ['Historia', 'Arte japonés'],
    lectura: '18 min',
    autor: 'tottibero',
    autorURL: 'https://fetlife.com/tottibero',
  },
];
---

<Layout
  title="Blog"
  description="Artículos sobre cultura BDSM, historia del erotismo, arte y sensualidad. Reflexiones desde la comunidad Fragua47."
>
  <section class="blog-index">
    <div class="blog-header">
      <h1>Fragua<span class="h1-num">47</span> · Artículos</h1>
      <hr class="linea-titulo" />
    </div>

    <ul class="lista-posts" role="list">
      {posts.map(post => (
        <li class="post-card">
          <div class="post-enlace">
            {post.imagen && (
              <a href={`/blog/${post.slug}/`} class="post-imagen-wrap" tabindex="-1" aria-hidden="true">
                <img src={post.imagen} alt={post.imagenAlt} class="post-imagen" loading="lazy" decoding="async" />
              </a>
            )}
            <div class="post-contenido">
              <div class="post-meta">
                <time class="post-fecha" datetime={post.fecha}>{post.fechaMostrar}</time>
              </div>
              <h2 class="post-titulo">
                <a href={`/blog/${post.slug}/`} class="post-titulo-enlace">{post.titulo}</a>
              </h2>
              <p class="post-resumen">{post.resumen}</p>
              <div class="post-footer">
                <div class="post-footer-izq">
                  {post.etiquetas && (
                    <ul class="post-etiquetas" aria-label="Categorías">
                      {post.etiquetas.map(e => <li class="post-etiqueta">{e}</li>)}
                    </ul>
                  )}
                  {post.lectura && (
                    <span class="post-lectura">
                      <svg class="icono-reloj" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M8 4.5V8.5L10.5 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                      {post.lectura}
                    </span>
                  )}
                  {post.autor && (
                    <span class="post-autor">
                      <svg class="icono-autor" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M2.5 13.5c0-3 2.5-4.5 5.5-4.5s5.5 1.5 5.5 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                      {post.autorURL
                        ? <a href={post.autorURL} class="post-autor-enlace" target="_blank" rel="noopener noreferrer">{post.autor}</a>
                        : post.autor
                      }
                    </span>
                  )}
                </div>
                <a href={`/blog/${post.slug}/`} class="post-leer">Leer artículo →</a>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .blog-index {
    width: 100%;
    padding: 1.5rem 0 2rem;
    font-family: 'Cinzel', serif;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .pre-titulo {
    font-size: 0.5rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #5a3018;
    margin-bottom: 0.2rem;
  }

  h1 {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: #2a1208;
    margin: 0 0 0.15rem;
  }
  .h1-num {
    color: #b44814;
  }

  .linea-titulo {
    border: none;
    border-top: 1.5px solid #2a1208;
    margin: 0.25rem auto 0.6rem;
    width: 80%;
    max-width: 340px;
  }

  .blog-intro {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.78rem;
    line-height: 1.7;
    color: #5a3018;
    margin: 0.5rem auto 0;
    max-width: 420px;
  }

  .lista-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .post-card {
    background: #d4b896;
    border: 3px solid #2a1208;
    outline: 1px solid #2a1208;
    outline-offset: 4px;
    box-shadow: 5px 5px 0 #2a1208;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .post-card:hover {
    box-shadow: 7px 7px 0 #2a1208;
    transform: translate(-1px, -1px);
  }

  .post-enlace {
    display: flex;
    color: inherit;
  }

  .post-imagen-wrap {
    flex: 0 0 130px;
    overflow: hidden;
    border-right: 2px solid #2a1208;
    text-decoration: none;
  }

  .post-imagen {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }

  .post-imagen-wrap:hover .post-imagen {
    transform: scale(1.03);
  }

  .post-titulo-enlace {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .post-titulo-enlace:hover {
    color: #b44814;
  }

  .post-leer {
    font-family: 'Cinzel', serif;
    font-size: 0.58rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #b44814;
    font-weight: 700;
    white-space: nowrap;
    text-decoration: none;
  }

  .post-contenido {
    padding: 1.2rem 1.5rem;
    flex: 1;
  }

  @media (max-width: 480px) {
    .post-enlace { flex-direction: column; }
    .post-imagen-wrap { flex: none; width: 100%; height: 120px; border-right: none; border-bottom: 2px solid #2a1208; }
  }

  .post-fecha {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 0.52rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #6a3010;
    margin-bottom: 0.35rem;
  }

  .post-titulo {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: #2a1208;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .post-card:hover .post-titulo {
    color: #b44814;
  }

  .post-resumen {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.78rem;
    line-height: 1.6;
    color: #3d2010;
    margin: 0 0 0.8rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.8rem;
  }

  .post-footer-izq {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .post-etiquetas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-etiqueta {
    font-family: 'Cinzel', serif;
    font-size: 0.46rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #2a1208;
    border: 1px solid #2a1208;
    padding: 0.15rem 0.5rem;
  }

  .post-lectura {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Cinzel', serif;
    font-size: 0.46rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #7a3a10;
  }

  .icono-reloj {
    width: 11px;
    height: 11px;
    color: #b44814;
    flex-shrink: 0;
  }

  .post-autor {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Cinzel', serif;
    font-size: 0.46rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #7a3a10;
  }

  .icono-autor {
    width: 11px;
    height: 11px;
    color: #b44814;
    flex-shrink: 0;
  }

  .post-autor-enlace {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid #8B1A1A;
    transition: color 0.2s;
  }
  .post-autor-enlace:hover { color: #8B1A1A; }

  @media (max-width: 768px) {
    .blog-index { padding: 1rem 0; }
    .post-contenido { padding: 1rem; }
    .post-titulo { font-size: 0.88rem; }
    .post-imagen-wrap { flex: 0 0 100px; }
  }
</style>
