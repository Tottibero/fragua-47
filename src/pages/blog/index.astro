---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'shunga-abunae-eroguro-erotismo-arte-japones',
    titulo: 'Shunga, Abunae y Eroguro: La Evolución del Erotismo en el Arte Japonés',
    resumen: 'Del período Edo hasta la vanguardia del siglo XX, el arte erótico japonés recorrió un camino fascinante entre lo sagrado, lo prohibido y lo transgresor. Un viaje por el shunga, el abunae y el eroguro.',
    fecha: '2026-04-08',
    fechaMostrar: '8 de abril de 2026',
  },
];
---

<Layout
  title="Blog"
  description="Artículos sobre cultura BDSM, historia del erotismo, arte y sensualidad. Reflexiones desde la comunidad Fragua47."
>
  <section class="blog-index">
    <div class="blog-header">
      <h1>Fragua<span class="h1-num">47</span> · Artículos</h1>
      <hr class="linea-titulo" />
    </div>

    <ul class="lista-posts" role="list">
      {posts.map(post => (
        <li class="post-card">
          <a href={`/blog/${post.slug}/`} class="post-enlace">
            <time class="post-fecha" datetime={post.fecha}>{post.fechaMostrar}</time>
            <h2 class="post-titulo">{post.titulo}</h2>
            <p class="post-resumen">{post.resumen}</p>
            <span class="post-leer" aria-hidden="true">Leer artículo →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .blog-index {
    width: 100%;
    padding: 1.5rem 0 2rem;
    font-family: 'Cinzel', serif;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .pre-titulo {
    font-size: 0.5rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #5a3018;
    margin-bottom: 0.2rem;
  }

  h1 {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: #2a1208;
    margin: 0 0 0.15rem;
  }
  .h1-num {
    color: #b44814;
  }

  .linea-titulo {
    border: none;
    border-top: 1.5px solid #2a1208;
    margin: 0.25rem auto 0.6rem;
    width: 80%;
    max-width: 340px;
  }

  .intro {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.78rem;
    color: #5a3018;
    margin: 0;
  }

  .lista-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .post-card {
    background: #d4b896;
    border: 3px solid #2a1208;
    outline: 1px solid #2a1208;
    outline-offset: 4px;
    box-shadow: 5px 5px 0 #2a1208;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .post-card:hover {
    box-shadow: 7px 7px 0 #2a1208;
    transform: translate(-1px, -1px);
  }

  .post-enlace {
    display: block;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .post-fecha {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 0.52rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #6a3010;
    margin-bottom: 0.35rem;
  }

  .post-titulo {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: #2a1208;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .post-card:hover .post-titulo {
    color: #b44814;
  }

  .post-resumen {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.78rem;
    line-height: 1.6;
    color: #3d2010;
    margin: 0 0 0.8rem;
  }

  .post-leer {
    font-family: 'Cinzel', serif;
    font-size: 0.58rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #b44814;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .blog-index { padding: 1rem 0; }
    .post-enlace { padding: 1rem; }
    .post-titulo { font-size: 0.88rem; }
  }
</style>
