---
import Layout from '../layouts/Layout.astro';
---

<Layout description="Hazte socio de Fragua47. Únete a nuestra comunidad y disfruta de todos los beneficios.">
	<div class="pagina">

		<div class="col-izquierda">
			<img src="/forjaSocios.png" alt="Hazte fragüero" class="portada" loading="eager" />
			<div class="text-col">
				<p class="pre-titulo">— únete —</p>
				<h2>Hazte Socio</h2>
				<hr class="titulo-linea" />
				<ul class="beneficios">
					<li>
						<svg class="icono" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v2m0 8v2M9.5 9.5A2.5 2.5 0 0 1 12 8c1.38 0 2.5.9 2.5 2s-1.12 2-2.5 2-2.5.9-2.5 2 1.12 2 2.5 2a2.5 2.5 0 0 0 2.5-1.5"/></svg>
						<span>Por sólo <strong>25 euros al mes</strong></span>
					</li>
					<li>
						<svg class="icono" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
						<span>hazte <strong>fragüero</strong></span>
					</li>
					<li>
						<svg class="icono" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
						<span>entrada <strong>GRATUITA</strong> a todos los eventos</span>
					</li>
					<li>
						<svg class="icono" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
						<span>acceso a la <strong>MAZMORRA</strong> ilimitado bajo reserva</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="documento">
			<div class="doc-header">
				<img src="/VectLogoF47.png" alt="Logo Fragua47" class="doc-logo" />
				<h3>Solicitud de membresía</h3>
				<span class="doc-sello">⚒</span>
			</div>
			<p class="doc-sub">— Formulario oficial de incorporación · Fragua47 · Valladolid —</p>

			<hr class="doc-linea" />

			<form id="form-socio">
				<div class="fila-campos">
					<div class="campo">
						<label for="correo">Correo electrónico <span class="req">*</span></label>
						<input type="email" id="correo" name="correo" required placeholder="tu@correo.com" />
					</div>
					<div class="campo">
						<label for="alias">Alias <span class="req">*</span></label>
						<input type="text" id="alias" name="alias" required placeholder="¿Cómo te conocemos?" />
					</div>
				</div>

				<div class="campo">
					<label for="fetlife">FetLife <span class="opcional">(opcional)</span></label>
					<input type="text" id="fetlife" name="fetlife" placeholder="Tu nick en FetLife" />
				</div>

				<div class="campo">
					<label for="notas">Cuéntanos algo <span class="opcional">(opcional)</span></label>
					<textarea id="notas" name="notas" rows="4" placeholder="Preguntas, inquietudes, de dónde vienes... lo que quieras contarnos."></textarea>
				</div>

				<hr class="doc-linea" />

				<div class="check-wrap">
					<input type="checkbox" id="acepto" name="acepto" required />
					<label for="acepto" class="check-label">Soy mayor de edad y acepto las normas de la comunidad</label>
				</div>

				<div class="doc-footer">
					<p class="form-msg" id="form-msg"></p>
					<button type="submit" id="form-btn">Quiero ser fragüero ⚒</button>
				</div>
			</form>
		</div>

	</div>
</Layout>

<style>
	.pagina {
		width: 100%;
		margin: 2rem auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		align-items: stretch;
		font-family: 'Cinzel', serif;
		color: #3d2010;
	}

	.col-izquierda {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.portada {
		width: 100%;
		flex: 1;
		min-height: 0;
		object-fit: cover;
		display: block;
		border: 3px solid #2a1208;
		outline: 1px solid #2a1208;
		outline-offset: 4px;
		box-shadow: 5px 5px 0 #2a1208;
	}

	.text-col {
		background: #d4b896;
		border: 3px solid #2a1208;
		outline: 1px solid #2a1208;
		outline-offset: 4px;
		box-shadow: 5px 5px 0 #2a1208;
		padding: 1.2rem 1.4rem;
	}

	.pre-titulo {
		font-size: 0.55rem;
		letter-spacing: 2.5px;
		text-transform: uppercase;
		color: #5a3018;
		margin-bottom: 0.3rem;
		text-align: center;
	}

	h2 {
		font-size: 1.2rem;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #2a1208;
		margin-bottom: 0.4rem;
		text-align: center;
		font-family: 'Cinzel', serif;
	}

	.titulo-linea {
		border: none;
		border-top: 1.5px solid #2a1208;
		margin: 0.4rem 0 0.9rem;
	}

	.beneficios {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.beneficios li {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.8rem;
		font-weight: 400;
		color: #2a1208;
		border-bottom: 1px solid rgba(42, 18, 8, 0.2);
		padding: 0.55rem 0;
	}

	.beneficios li:last-child {
		border-bottom: none;
	}

	.icono {
		width: 0.85rem;
		height: 0.85rem;
		min-width: 0.85rem;
		color: #b44814;
		stroke: #b44814;
		flex-shrink: 0;
	}

	.beneficios strong {
		font-weight: 700;
		color: #b44814;
	}

	/* ── Documento ── */

	.documento {
		background: #d4b896;
		border: 3px solid #2a1208;
		outline: 1px solid #2a1208;
		outline-offset: 5px;
		box-shadow: 6px 6px 0 #2a1208;
		padding: 1.6rem 1.8rem;
		font-family: 'Cinzel', serif;
	}

	.doc-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		margin-bottom: 0.5rem;
	}

	.doc-logo {
		height: 28px;
		width: auto;
		flex-shrink: 0;
	}

	.doc-sello {
		font-size: 1.4rem;
		font-weight: 900;
		color: #b44814;
		letter-spacing: 2px;
		flex-shrink: 0;
	}

	h3 {
		font-size: 1rem;
		letter-spacing: 4px;
		text-transform: uppercase;
		color: #2a1208;
		margin: 0;
		text-align: center;
		font-family: 'Cinzel', serif;
	}

	.doc-sub {
		font-size: 0.6rem;
		letter-spacing: 1.5px;
		color: #5a3018;
		text-align: center;
		margin: 0 0 0.8rem;
		text-transform: uppercase;
	}

	.doc-linea {
		border: none;
		border-top: 1.5px solid #2a1208;
		margin: 1rem 0;
	}

	.fila-campos {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.2rem;
	}

	.campo {
		display: flex;
		flex-direction: column;
		margin-bottom: 1rem;
	}

	label {
		font-family: 'Cinzel', serif;
		font-size: 0.6rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #2a1208;
		margin-bottom: 0.3rem;
		font-weight: 700;
	}

	.req { color: #b44814; }

	.opcional {
		font-family: system-ui, -apple-system, sans-serif;
		font-weight: 400;
		text-transform: none;
		letter-spacing: 0;
		color: #5a3018;
		font-size: 0.65rem;
	}

	input, textarea {
		background: rgba(255,255,255,0.3);
		border: none;
		border-bottom: 1.5px solid #2a1208;
		padding: 0.4rem 0.3rem;
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.82rem;
		color: #1c0a02;
		outline: none;
		transition: border-color 0.2s, background 0.2s;
	}

	textarea {
		border: 1.5px solid #2a1208;
		padding: 0.5rem;
		resize: vertical;
	}

	input:focus, textarea:focus {
		border-color: #b44814;
		background: rgba(255,255,255,0.5);
	}

	input::placeholder, textarea::placeholder {
		color: #7a5035;
		font-style: italic;
		font-size: 0.75rem;
	}

	.check-wrap {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-bottom: 1.2rem;
	}

	.check-wrap input[type="checkbox"] {
		appearance: none;
		-webkit-appearance: none;
		width: 16px;
		height: 16px;
		min-width: 16px;
		border: 2px solid #2a1208;
		background: rgba(255,255,255,0.3);
		cursor: pointer;
		position: relative;
		padding: 0;
		transition: background 0.2s, border-color 0.2s;
	}

	.check-wrap input[type="checkbox"]:checked {
		background: #2a1208;
		border-color: #2a1208;
	}

	.check-wrap input[type="checkbox"]:checked::after {
		content: '';
		position: absolute;
		left: 3px;
		top: 0px;
		width: 5px;
		height: 9px;
		border: 2px solid #f5e6d0;
		border-top: none;
		border-left: none;
		transform: rotate(45deg);
	}

	.check-wrap input[type="checkbox"]:focus {
		border-color: #b44814;
		outline: none;
	}

	.check-label {
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.75rem;
		color: #2a1208;
		font-weight: 500;
		cursor: pointer;
		line-height: 1.5;
		margin: 0;
	}

	.doc-footer {
		display: flex;
		justify-content: flex-end;
	}

	button {
		background: #b44814;
		color: #fff7ee;
		border: none;
		padding: 0.75rem 1.6rem;
		font-family: 'Cinzel', serif;
		font-size: 0.75rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		cursor: pointer;
		transition: background 0.2s, box-shadow 0.2s;
		white-space: nowrap;
		box-shadow: 3px 3px 0 #6a2808;
	}

	button:hover {
		background: #d45a18;
		box-shadow: 4px 4px 0 #6a2808;
	}

	@media (max-width: 768px) {
		.pagina {
			grid-template-columns: 1fr;
			margin: 1.5rem auto;
			gap: 1.5rem;
		}
		.fila-campos {
			grid-template-columns: 1fr;
		}
	}

	.form-msg {
		font-family: system-ui, -apple-system, sans-serif;
		font-size: 0.72rem;
		margin: 0;
	}
	.form-msg.ok    { color: #2a6a1a; }
	.form-msg.error { color: #b41414; }

	::selection {
		background: rgba(180, 80, 20, 0.35);
		color: #ffe0b0;
	}
</style>

<script is:inline>
	document.getElementById('form-socio')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = e.target;
		const btn  = document.getElementById('form-btn');
		const msg  = document.getElementById('form-msg');
		btn.disabled = true;
		btn.textContent = 'Enviando...';
		msg.className = 'form-msg';
		msg.textContent = '';
		const correo  = document.getElementById('correo').value.trim();
		const alias   = document.getElementById('alias').value.trim();
		const fetlife = document.getElementById('fetlife').value.trim();
		const notas   = document.getElementById('notas').value.trim();
		const res = await fetch('/api/socio', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ correo, alias, fetlife, notas }) });
		if (res.ok) {
			msg.className = 'form-msg ok';
			msg.textContent = '¡Solicitud enviada! Te contactamos pronto.';
			form.reset();
		} else {
			msg.className = 'form-msg error';
			msg.textContent = 'Error al enviar. Inténtalo de nuevo.';
		}
		btn.disabled = false;
		btn.textContent = 'Quiero ser fragüero ⚒';
	});
</script>
